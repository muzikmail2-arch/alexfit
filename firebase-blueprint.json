{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Store user accounts, settings, and subscription status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "subscriptionStatus": { "type": "string", "enum": ["free", "premium"] },
        "subscriptionTier": { "type": "string", "enum": ["monthly", "yearly", "none"] },
        "subscriptionExpiry": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" },
        "fitnessGoals": { "type": "string" },
        "weight": { "type": "number" },
        "height": { "type": "number" },
        "gender": { "type": "string" }
      },
      "required": ["uid", "email", "role", "subscriptionStatus"]
    },
    "Workout": {
      "title": "Workout Program / Exercise",
      "description": "Represents an individual exercise or pre-made workout routine.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "muscleGroups": { "type": "array" },
        "difficulty": { "type": "string" },
        "instructions": { "type": "array" },
        "equipment": { "type": "array" },
        "category": { "type": "string" },
        "illustrationSvg": { "type": "string" },
        "commonMistakes": { "type": "array" },
        "safetyTips": { "type": "array" },
        "alternativeExercises": { "type": "array" },
        "progressionVariations": { "type": "array" },
        "isPremium": { "type": "boolean" }
      },
      "required": ["id", "name", "category", "isPremium"]
    },
    "UserWorkoutAction": {
      "title": "Saved / Completed Workout",
      "description": "User specific custom logged active session or favorite workout status.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "workoutId": { "type": "string" },
        "completed": { "type": "boolean" },
        "saved": { "type": "boolean" },
        "loggedAt": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "workoutId"]
    },
    "ProgressLog": {
      "title": "User Weight or Metric Log",
      "description": "Allows tracking muscle specs, body weights, and personal tracking records.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "weight": { "type": "number" },
        "bodyFat": { "type": "number" },
        "calories": { "type": "number" },
        "date": { "type": "string", "format": "date-time" },
        "notes": { "type": "string" }
      },
      "required": ["id", "userId", "date"]
    },
    "Transaction": {
      "title": "Paystack Subscription Payment",
      "description": "Details of user paystack invoice receipts.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "reference": { "type": "string" },
        "amount": { "type": "number" },
        "status": { "type": "string" },
        "plan": { "type": "string" },
        "paidAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "reference", "amount", "status"]
    },
    "AICoachChat": {
      "title": "AI Coach Conversation Node",
      "description": "Log of messages exchanged between the premium user and the AI coach.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "role", "message", "timestamp"]
    },
    "CustomProgram": {
      "title": "Custom Workout Program",
      "description": "User created structured training programs built from the exercise library.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "schedule": { "type": "array" }
      },
      "required": ["id", "userId", "name", "schedule"]
    },
    "FavoriteVideo": {
      "title": "Favorite Video Link",
      "description": "Logged-in user favorited gym or home workout videos.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "videoId": { "type": "string" },
        "title": { "type": "string" },
        "channelTitle": { "type": "string" },
        "thumbnail": { "type": "string" },
        "duration": { "type": "string" },
        "viewCount": { "type": "string" },
        "publishedAt": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "videoId", "title", "savedAt"]
    },
    "VideoSearchHistory": {
      "title": "Video Search Log",
      "description": "Logged-in user search trail for autocomplete recommendations.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "query": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "userId", "query", "timestamp"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Primary user profile document containing details about their subscription and metadata."
    },
    "exercises/{exerciseId}": {
      "schema": "Workout",
      "description": "Comprehensive exercises database documents which can be added by admin."
    },
    "user_workout_actions/{actionId}": {
      "schema": "UserWorkoutAction",
      "description": "User records for saved or completed exercises/workouts."
    },
    "progress_logs/{logId}": {
      "schema": "ProgressLog",
      "description": "Periodic stats logs for graph display on the dashboard."
    },
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Historical audit of Paystack subscription purchases."
    },
    "ai_coach_chats/{chatId}": {
      "schema": "AICoachChat",
      "description": "Conversation nodes tracking prompt interactions with the AI coach."
    },
    "custom_programs/{programId}": {
      "schema": "CustomProgram",
      "description": "User created custom structured workout programs for premium dashboard."
    },
    "favorite_videos/{favoriteId}": {
      "schema": "FavoriteVideo",
      "description": "User's bookmarked or pinned workout video cards."
    },
    "video_search_history/{historyId}": {
      "schema": "VideoSearchHistory",
      "description": "Historic search queries triggered by user of videos page."
    }
  }
}
