@import "tailwindcss";

@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;750&display=swap');

@theme {
  --font-sans: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-serif: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-display: "Helvetica Neue", Helvetica, Arial, sans-serif;
  --font-mono: "Helvetica Neue", Helvetica, Arial, sans-serif;
}

@layer base {
  body {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif !important;
    background-color: #FFFFFF !important;
    color: #000000 !important;
  }
}

/* ==========================================
   ALEXFITNESSHUB GLOBAL PALETTE ENFORCEMENT
   1. White Background entirely
   2. Red Headers (#D32F2F)
   3. Black Text (#000000)
   4. Helvetica Font family
   ========================================== */

/* Force all text font to Helvetica family */
* {
  font-family: "Helvetica Neue", Helvetica, Arial, sans-serif !important;
}

/* White background entirely across body, panels, sidebars, containers, and views */
html, body, #root, #home-view-root, main, section, footer, article, aside {
  background-color: #FFFFFF !important;
  background-image: none !important;
  color: #000000 !important;
}

/* Force white background for all cards, list rows, bento blocks, tabs, code, drawers, and overlays */
.bg-white, .bg-slate-50, .bg-slate-100, .bg-slate-200, .bg-slate-300, .bg-slate-900, .bg-slate-950, 
.bg-gray-50, .bg-gray-100, .bg-gray-200, .bg-gray-900, .bg-zinc-900, .bg-black, .bg-[#1C1C1C], .bg-emerald-950\/20,
.bg-slate-50\/50, .bg-slate-900\/40, .bg-slate-900\/60, .bg-slate-50\/50, .bg-slate-900\/40, .bg-slate-900\/60,
.bg-red-50, .bg-red-100, .bg-sky-50, .bg-emerald-500\/5, .bg-emerald-550 {
  background-color: #FFFFFF !important;
  color: #000000 !important;
  border-color: #E2E8F0 !important; /* Elegant light slate borders */
}

/* Allow Green (#2E7D32) as an accent color for success, active, achievements, progress indicators and badges */
.text-green-600, .text-emerald-600, .text-green-700, .text-emerald-700, .text-achievement, .text-emerald-500, .text-green-500 {
  color: #2E7D32 !important;
}

.bg-green-50, .bg-emerald-50, .bg-green-100, .bg-emerald-100, .bg-emerald-500\/10 {
  background-color: #E8F5E9 !important; /* Very soft light green background */
  color: #2E7D32 !important;
  border-color: #C8E6C9 !important;
}

.bg-green-600, .bg-emerald-600, .bg-green-700, .bg-emerald-700, .bg-achievement, .bg-emerald-500, .bg-green-500 {
  background-color: #2E7D32 !important;
  color: #FFFFFF !important;
}

.bg-green-600 *, .bg-emerald-600 *, .bg-green-700 *, .bg-emerald-700 *, .bg-achievement *, .bg-emerald-500 *, .bg-green-500 * {
  color: #FFFFFF !important;
}

/* Keep borders visible and elegant in high-contrast light mode */
.border, .border-slate-200, .border-slate-800, .border-slate-150, .border-slate-850, .border-dashed, .border-t, .border-b, .border-r, .border-l {
  border-color: #E2E8F0 !important;
}

/* Make sure headers are ALWAYS our crisp Red */
h1, h2, h3, h4, h5, h6, 
.font-black, .font-extrabold, 
h1 *, h2 *, h3 *, h4 *, h5 *, h6 * {
  color: #D32F2F !important;
}

/* Make sure text elements are ALWAYS Black unless they are specifically styled as achievements, white text in buttons, or active states */
p, li, span, div, label, td, th, input, select, textarea, button:not(.bg-\[\#D32F2F\]):not(.text-white):not(.text-emerald-600):not(.text-green-600):not(.bg-green-600):not(.bg-emerald-600):not(.text-green-500):not(.bg-green-500):not(.text-emerald-500):not(.bg-emerald-500) {
  color: #000000 !important;
}

/* Ensure our red is applied universally to active icons and highlights */
.text-\[\#C0392B\], .text-red-500, .text-red-600, .text-rose-600, .text-\[\#D32F2F\] {
  color: #D32F2F !important;
}

/* Standardize Interactive Buttons */
/* Make solid buttons stand out elegantly in solid Red background with crisp White text */
button.bg-\[\#C0392B\], button.bg-\[\#D32F2F\], button.bg-emerald-500, button.bg-sky-500, button.bg-black, button.bg-slate-900,
button[type="submit"], button[type="button"].bg-emerald-500, button[type="button"].bg-sky-500,
.bg-emerald-500, .bg-\[\#C0392B\], .bg-\[\#D32F2F\], .bg-sky-500, .bg-black, .bg-slate-900,
.bg-\[\#C0392B\] button, .bg-\[\#D32F2F\] button, .bg-emerald-600, .bg-emerald-550, .bg-emerald-500 {
  background-color: #D32F2F !important;
  color: #FFFFFF !important;
  border-color: #D32F2F !important;
}

/* Keep actual text inside primary red buttons as White */
button.bg-\[\#C0392B\] *, button.bg-\[\#D32F2F\] *, button.bg-emerald-500 *, button.bg-sky-500 *, button.bg-black *, button.bg-slate-900 *,
.bg-\[\#C0392B\] *, .bg-\[\#D32F2F\] *, .bg-\[\#C0392B\] span, .bg-\[\#D32F2F\] span, .bg-emerald-500 span, .bg-emerald-500 p, .bg-emerald-500 *, .bg-emerald-600 * {
  color: #FFFFFF !important;
}

/* Secondary outline buttons style */
button.border, button.border-slate-200, button.border-red-200 {
  background-color: #FFFFFF !important;
  color: #D32F2F !important;
  border: 1px solid #D32F2F !important;
}
button.border * {
  color: #D32F2F !important;
}

/* Standardize Input Fields & Select Dropdowns */
input, select, textarea {
  background-color: #FFFFFF !important;
  color: #000000 !important;
  border: 1px solid #CBD5E1 !important;
}
input::placeholder, textarea::placeholder {
  color: #94A3B8 !important;
}

/* Sticky header background retains red header look nicely */
header.bg-\[\#C0392B\], header.bg-\[\#D32F2F\], header {
  background-color: #D32F2F !important;
}
header * {
  color: #FFFFFF !important;
}

/* Active links inside navbar */
header nav a, header span, header button {
  color: #FFFFFF !important;
}

/* Fix any modals or blur overlays to remain white/light instead of black/dark */
.bg-slate-950\/75, .bg-black\/75, .bg-black\/40 {
  background-color: rgba(255, 255, 255, 0.9) !important;
  backdrop-filter: blur(4px) !important;
}

.animate-fade-in {
  animation: fadeIn 0.3s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-slide-in {
  animation: slideIn 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.animate-slide-down {
  animation: slideDown 0.35s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

@keyframes fadeIn {
  from { opacity: 0; transform: scale(0.99); }
  to { opacity: 1; transform: scale(1); }
}

@keyframes slideIn {
  from { opacity: 0; transform: translateX(40px); }
  to { opacity: 1; transform: translateX(0); }
}

@keyframes slideDown {
  from { opacity: 0; transform: translateY(-30px); }
  to { opacity: 1; transform: translateY(0); }
}
